{
  "name": "whitepenguin-backend",
  "version": "1.0.0",
  "description": "TypeScript Node.js backend for White Penguin project",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc --project ./tsconfig.json --incremental false && node scripts/copy-shared-templates.js && echo ✅✅✅",
    "start": "node dist/index.modular.js",
    "start:modular": "node dist/index.modular.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "dev:modular": "ts-node-dev --respawn --transpile-only src/index.modular.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:daily-report": "jest src/modules/attendance/__tests__/daily-activity-report.e2e.test.ts",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "clean": "rm -rf dist",
    "typeorm": "typeorm-ts-node-commonjs",
    "migration:generate": "npm run typeorm migration:generate -- -d src/modules/core/config/database.ts",
    "migration:run": "npm run typeorm migration:run -- -d src/modules/core/config/database.ts",
    "migration:revert": "npm run typeorm migration:revert -- -d src/modules/core/config/database.ts",
    "schema:sync": "npm run typeorm schema:sync -- -d src/modules/core/config/database.ts",
    "schema:drop": "npm run typeorm schema:drop -- -d src/modules/core/config/database.ts",
    "seed": "node seed-database.js",
    "seed:super-admin": "node create-super-admin.js",
    "seed:test": "ts-node src/modules/shared/seed/run-seeder.ts seed",
    "seed:test:clear": "ts-node src/modules/shared/seed/run-seeder.ts clear",
    "seed:test:refresh": "ts-node src/modules/shared/seed/run-seeder.ts refresh",
    "seed:test:stats": "ts-node src/modules/shared/seed/run-seeder.ts stats",
    "db:reset": "node reset-database.js",
    "db:setup": "npm run migration:run && npm run seed"
  },
  "keywords": [
    "typescript",
    "nodejs",
    "backend",
    "api"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@sendgrid/mail": "^8.1.6",
    "@types/bcrypt": "^6.0.0",
    "@types/multer": "^2.0.0",
    "@types/passport": "^1.0.17",
    "@types/passport-facebook": "^3.0.3",
    "@types/passport-google-oauth20": "^2.0.16",
    "@types/passport-linkedin-oauth2": "^1.5.6",
    "@types/puppeteer": "^5.4.7",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-rate-limit": "^8.0.1",
    "express-validator": "^7.0.1",
    "firebase-admin": "^13.5.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mailtrap": "^4.4.0",
    "morgan": "^1.10.0",
    "multer": "^2.0.2",
    "mysql2": "^3.15.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^7.0.5",
    "passport": "^0.7.0",
    "passport-facebook": "^3.0.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-linkedin-oauth2": "^2.0.0",
    "pg": "^8.11.3",
    "puppeteer": "^24.38.0",
    "qrcode": "^1.5.4",
    "reflect-metadata": "^0.1.13",
    "resend": "^6.6.0",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.1",
    "speakeasy": "^2.0.0",
    "twilio": "^5.12.0",
    "typeorm": "^0.3.17"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.5",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.4",
    "@types/mysql": "^2.15.27",
    "@types/node": "^20.8.0",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^7.0.1",
    "@types/pg": "^8.10.7",
    "@types/qrcode": "^1.5.5",
    "@types/sharp": "^0.31.1",
    "@types/speakeasy": "^2.0.10",
    "@types/supertest": "^2.0.14",
    "@typescript-eslint/eslint-plugin": "^6.8.0",
    "@typescript-eslint/parser": "^6.8.0",
    "axios": "^1.11.0",
    "eslint": "^8.51.0",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "ts-jest": "^29.4.11",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.2.2"
  }
}
